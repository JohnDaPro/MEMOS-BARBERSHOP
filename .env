# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Admin ────────────────────────────────────────────────────────────
# Password the barber uses to log in to the admin panel
ADMIN_PASSWORD=MEMOS123

# Secret used to sign admin JWT tokens (use a long random string)
JWT_SECRET=replace-with-long-random-string

# ── Facebook Login ────────────────────────────────────────────────────
# Get this from https://developers.facebook.com → your app → Settings → Basic
FACEBOOK_APP_ID=XXXXXXXXXX

# ── Vonage SMS ────────────────────────────────────────────────────────
# Get these from https://dashboard.nexmo.com/settings
VONAGE_API_KEY=xxxxxxxx
VONAGE_API_SECRET=xxxxxxxxxxxxxxxx

# ── SETUP NOTES ───────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in your values
# 2. For Vonage SMS OTP:
#    - Create a free account at https://dashboard.nexmo.com
#    - Copy your API Key and API Secret from the dashboard
#    - Vonage includes free trial credits for testing
# 3. If VONAGE vars are missing/placeholder, the server runs in DEV mode:
#    OTP codes are printed to the console instead of sent via SMS
