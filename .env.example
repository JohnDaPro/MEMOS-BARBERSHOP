# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Admin ────────────────────────────────────────────────────────────
# Password the barber uses to log in to the admin panel
ADMIN_PASSWORD=NIGGER67

# Secret used to sign admin JWT tokens (use a long random string)
JWT_SECRET=replace-with-long-random-string

# ── Twilio WhatsApp ───────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For WhatsApp Sandbox (testing): whatsapp:+14155238886
# For production WhatsApp Business: whatsapp:+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SETUP NOTES ───────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in your values
# 2. For Twilio WhatsApp Sandbox (free testing):
#    - Go to https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
#    - Follow instructions to join the sandbox from your phone
#    - Use the sandbox number above for TWILIO_WHATSAPP_FROM
# 3. If TWILIO vars are missing, the server runs in DEV mode:
#    OTP codes are printed to the console instead of sent via WhatsApp
